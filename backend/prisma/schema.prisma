generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  passwordResetTokenHash String?   @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  role         Role     @default(learner)
  avatarUrl    String?  @map("avatar_url")
  totalPoints  Int      @default(0) @map("total_points")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  coursesResponsible  Course[]            @relation("ResponsibleUser")
  lessonsResponsible  Lesson[]            @relation("LessonResponsible")
  enrollments         Enrollment[]
  lessonProgress      LessonProgress[]
  quizAttempts        QuizAttempt[]
  reviews             Review[]
  payments            Payment[]
  invitationsSent     CourseInvitation[]  @relation("InvitedBy")
  invitationsReceived CourseInvitation[]  @relation("InvitedUser")

  @@map("users")
}

enum Role {
  admin
  instructor
  learner
}

model Course {
  id             String     @id @default(uuid())
  title          String
  shortDesc      String?    @map("short_desc")
  description    String?
  coverImageUrl  String?    @map("cover_image_url")
  tags           String[]
  websiteUrl     String?    @map("website_url")
  responsibleId  String?    @map("responsible_id")
  isPublished    Boolean    @default(false) @map("is_published")
  publishedAt    DateTime?  @map("published_at")
  visibility     Visibility @default(everyone)
  accessRule     AccessRule @default(open) @map("access_rule")
  price          Decimal?   @db.Decimal(10, 2)
  viewsCount     Int        @default(0) @map("views_count")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  // Relations
  responsible  User?              @relation("ResponsibleUser", fields: [responsibleId], references: [id])
  lessons      Lesson[]
  quizzes      Quiz[]
  enrollments  Enrollment[]
  invitations  CourseInvitation[]
  reviews      Review[]
  payments     Payment[]

  @@map("courses")
}

enum Visibility {
  everyone
  signed_in
}

enum AccessRule {
  open
  invitation
  payment
}

model Lesson {
  id            String      @id @default(uuid())
  courseId       String      @map("course_id")
  title         String
  lessonType    LessonType  @map("lesson_type")
  description   String?
  videoUrl      String?     @map("video_url")
  durationMins  Int?        @map("duration_mins")
  fileUrl       String?     @map("file_url")
  allowDownload Boolean     @default(false) @map("allow_download")
  sortOrder     Int         @default(0) @map("sort_order")
  responsibleId String?     @map("responsible_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations
  course       Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  responsible  User?               @relation("LessonResponsible", fields: [responsibleId], references: [id])
  attachments  LessonAttachment[]
  progress     LessonProgress[]
  quiz         Quiz?               @relation("QuizLesson")

  @@map("lessons")
}

enum LessonType {
  video
  document
  image
  quiz
}

model LessonAttachment {
  id             String         @id @default(uuid())
  lessonId       String         @map("lesson_id")
  attachmentType AttachmentType @map("attachment_type")
  label          String
  url            String
  sortOrder      Int            @default(0) @map("sort_order")
  createdAt      DateTime       @default(now()) @map("created_at")

  // Relations
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_attachments")
}

enum AttachmentType {
  file
  link
}

model Quiz {
  id                 String   @id @default(uuid())
  courseId            String   @map("course_id")
  lessonId           String?  @unique @map("lesson_id")
  title              String
  pointsAttempt1     Int      @default(10) @map("points_attempt_1")
  pointsAttempt2     Int      @default(7)  @map("points_attempt_2")
  pointsAttempt3     Int      @default(4)  @map("points_attempt_3")
  pointsAttempt4plus Int      @default(2)  @map("points_attempt_4plus")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson?       @relation("QuizLesson", fields: [lessonId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id           String   @id @default(uuid())
  quizId       String   @map("quiz_id")
  questionText String   @map("question_text")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]
  answers QuizAttemptAnswer[]

  @@map("quiz_questions")
}

model QuizOption {
  id         String  @id @default(uuid())
  questionId String  @map("question_id")
  optionText String  @map("option_text")
  isCorrect  Boolean @default(false) @map("is_correct")
  sortOrder  Int     @default(0) @map("sort_order")

  // Relations
  question QuizQuestion       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  QuizAttemptAnswer[]

  @@map("quiz_options")
}

model Enrollment {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  courseId       String           @map("course_id")
  status        EnrollmentStatus @default(not_started)
  enrolledAt    DateTime         @default(now()) @map("enrolled_at")
  startedAt     DateTime?        @map("started_at")
  completedAt   DateTime?        @map("completed_at")
  timeSpentMins Int              @default(0) @map("time_spent_mins")
  isPaid        Boolean          @default(false) @map("is_paid")
  paidAt        DateTime?        @map("paid_at")
  amountPaid    Decimal?         @db.Decimal(10, 2) @map("amount_paid")

  // Relations
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
  quizAttempts   QuizAttempt[]
  payments       Payment[]

  @@unique([userId, courseId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  not_started
  in_progress
  completed
}

enum PaymentProvider {
  razorpay
  stripe
}

enum PaymentStatus {
  created
  verified
  failed
}

model Payment {
  id                String          @id @default(uuid())
  userId            String          @map("user_id")
  courseId          String          @map("course_id")
  enrollmentId      String?         @map("enrollment_id")
  provider          PaymentProvider @default(stripe)
  status            PaymentStatus   @default(created)
  currency          String          @default("INR")
  amount            Decimal         @db.Decimal(10, 2)
  receipt           String?         @map("receipt")
  providerOrderId   String          @unique @map("provider_order_id")
  providerPaymentId String?         @unique @map("provider_payment_id")
  providerSignature String?         @map("provider_signature")
  providerPayload   Json?           @map("provider_payload")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  paidAt            DateTime?       @map("paid_at")
  failedAt          DateTime?       @map("failed_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@map("payments")
}

model LessonProgress {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  lessonId     String    @map("lesson_id")
  enrollmentId String    @map("enrollment_id")
  isCompleted  Boolean   @default(false) @map("is_completed")
  completedAt  DateTime? @map("completed_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model QuizAttempt {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  quizId         String   @map("quiz_id")
  enrollmentId   String   @map("enrollment_id")
  attemptNumber  Int      @map("attempt_number")
  totalQuestions Int      @map("total_questions")
  correctAnswers Int      @default(0) @map("correct_answers")
  pointsEarned   Int      @default(0) @map("points_earned")
  passed         Boolean  @default(false)
  attemptedAt    DateTime @default(now()) @map("attempted_at")

  // Relations
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz       Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  enrollment Enrollment         @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  answers    QuizAttemptAnswer[]

  @@map("quiz_attempts")
}

model QuizAttemptAnswer {
  id               String  @id @default(uuid())
  attemptId        String  @map("attempt_id")
  questionId       String  @map("question_id")
  selectedOptionId String? @map("selected_option_id")
  isCorrect        Boolean @default(false) @map("is_correct")

  // Relations
  attempt        QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption QuizOption?  @relation(fields: [selectedOptionId], references: [id])

  @@map("quiz_attempt_answers")
}

model Review {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  courseId    String   @map("course_id")
  rating     Int
  reviewText String?  @map("review_text")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("reviews")
}

model CourseInvitation {
  id         String           @id @default(uuid())
  courseId    String           @map("course_id")
  invitedBy  String           @map("invited_by")
  email      String
  userId     String?          @map("user_id")
  status     InvitationStatus @default(pending)
  token      String           @unique
  invitedAt  DateTime         @default(now()) @map("invited_at")
  acceptedAt DateTime?        @map("accepted_at")
  expiresAt  DateTime         @map("expires_at")

  // Relations
  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  inviter     User   @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)
  invitedUser User?  @relation("InvitedUser", fields: [userId], references: [id])

  @@unique([courseId, email])
  @@map("course_invitations")
}

enum InvitationStatus {
  pending
  accepted
  expired
}
